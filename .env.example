# --- Postgres (docker compose) ---
POSTGRES_USER=yesip
POSTGRES_PASSWORD=yesip_dev
POSTGRES_DB=yesip
POSTGRES_PORT=5432

# --- App connection string ---
DATABASE_URL=postgres://yesip:yesip_dev@localhost:5432/yesip

# --- API ---
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Cloudflare DNS (Fase 2.3) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_BASE_DOMAIN=meudns.dev

# --- Trust proxy (Fly.io / Cloudflare) ---
TRUST_PROXY=true
