# =============================================================================
# yes-ip — environment variables template
# Copy this file to .env and fill in real values:  cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Postgres (docker compose)
# -----------------------------------------------------------------------------
# These four variables drive the postgres:16-alpine container defined in
# docker-compose.yml. They must match what DATABASE_URL points to. In
# production, ignore these and set DATABASE_URL directly to your managed DB
# (Neon, Supabase, RDS, etc.).
POSTGRES_USER=yesip
POSTGRES_PASSWORD=yesip_dev
POSTGRES_DB=yesip
# Host port mapped to the container's 5432. Change if 5432 is already in use.
POSTGRES_PORT=5432


# -----------------------------------------------------------------------------
# App database connection
# -----------------------------------------------------------------------------
# Full connection string used by the API and by drizzle-kit. For local dev,
# this matches the docker compose values above. For production (Neon), copy
# the connection string from the Neon dashboard:
#   Neon → your project → Connection Details → "Direct connection" → copy.
# Example Neon URL:
#   postgres://USER:PASSWORD@ep-xxx.region.aws.neon.tech/yesip?sslmode=require
DATABASE_URL=postgres://yesip:yesip_dev@localhost:5432/yesip


# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Bind address and port for Fastify. Use 0.0.0.0 inside containers so the
# port is reachable from outside the container.
API_HOST=0.0.0.0
API_PORT=3000
# development | test | production. Controls pino-pretty logging.
NODE_ENV=development
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info


# -----------------------------------------------------------------------------
# Cloudflare DNS (used to push DDNS updates to your zone)
# -----------------------------------------------------------------------------
# Prerequisite: your domain's nameservers must point to Cloudflare.
#   Cloudflare Dashboard → Add Site → follow the instructions to change NS
#   records at your registrar. Wait for "Active" status.
#
# How to obtain CLOUDFLARE_API_TOKEN:
#   1. https://dash.cloudflare.com/profile/api-tokens
#   2. Click "Create Token"
#   3. Use the template "Edit zone DNS"
#   4. Zone Resources → Include → Specific zone → <your-domain.tld>
#   5. (Optional) Restrict by IP / TTL
#   6. Continue → Create Token → copy the value (shown only once)
# Required permission: Zone.DNS:Edit on the target zone.
CLOUDFLARE_API_TOKEN=

# How to obtain CLOUDFLARE_ZONE_ID:
#   1. Cloudflare Dashboard → click your domain
#   2. On the Overview tab, right-hand sidebar → "API" section
#   3. Copy "Zone ID" (32-char hexadecimal string)
CLOUDFLARE_ZONE_ID=

# Apex domain that the API is allowed to write into. The /nic/update endpoint
# rejects hostnames that are not equal to or a subdomain of this value.
# Example: with CLOUDFLARE_BASE_DOMAIN=yesip.dev, "home.yesip.dev" is allowed
# but "evil.com" is rejected with "nohost". Use the same domain you added to
# Cloudflare above. Leave blank to disable the check (NOT recommended).
CLOUDFLARE_BASE_DOMAIN=yesip.dev

# Whether to publish records as Cloudflare-proxied (orange cloud) or DNS-only
# (grey cloud).
#   false → DNS only. Recommended for DDNS — clients see the real IP.
#   true  → Proxied. Cloudflare hides the origin IP behind its anycast
#           network; only useful if the host is serving HTTP(S) traffic
#           through Cloudflare. Most home routers want DNS-only.
CLOUDFLARE_PROXIED=false


# -----------------------------------------------------------------------------
# Reverse proxy trust
# -----------------------------------------------------------------------------
# When TRUST_PROXY=true, Fastify reads the client IP from the
# X-Forwarded-For / Fly-Client-IP header instead of the socket. Required when
# running behind Cloudflare proxy or on Fly.io. Set to false only for direct
# exposure (e.g. local development without a tunnel).
TRUST_PROXY=true


# -----------------------------------------------------------------------------
# Web panel (better-auth)
# -----------------------------------------------------------------------------
# Public URL where the Next.js panel is served. Used as the cookie domain and
# to validate auth callbacks. In dev: http://localhost:3001. In production
# use the full HTTPS URL (e.g. https://panel.yesip.dev).
BETTER_AUTH_URL=http://localhost:3001

# Random 32+ byte secret used to sign sessions. Generate with:
#   openssl rand -base64 48
# NEVER commit a real secret. Rotate if leaked — all sessions invalidate.
BETTER_AUTH_SECRET=replace_me_with_openssl_rand_base64_48
